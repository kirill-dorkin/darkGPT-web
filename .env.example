# DarkGPT Web configuration
APP_ENV=development
DEFAULT_LANGUAGE=en
SUPPORT_USERNAME=@darkgpt_support

# Telegram Login. BOT_TOKEN is server-only; TELEGRAM_BOT_USERNAME is public.
BOT_TOKEN=
TELEGRAM_BOT_USERNAME=dark2_gpt_bot
# Optional. Use the Client ID from @BotFather > Bot Settings > Web Login.
# If empty, the app falls back to the numeric id from BOT_TOKEN.
TELEGRAM_CLIENT_ID=

# Shared runtime database. Use the pooled Neon URL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Crypto Bot Crypto Pay top-ups.
CRYPTO_PAY_API_KEY=
CRYPTO_PAY_BASE_URL=https://pay.crypt.bot/api

# AI provider: demo, gemini, openrouter, runpod, replicate.
AI_PROVIDER=gemini
AI_DEFAULT_TIER=standard
AI_TIMEOUT_SECONDS=45
AI_MAX_OUTPUT_TOKENS=350
AI_FALLBACK_PROVIDERS=openrouter

# Model router tiers.
AI_LITE_PROVIDER=gemini
AI_LITE_MODEL=gemini-2.5-flash-lite
AI_LITE_CREDITS=12
AI_LITE_MAX_OUTPUT_TOKENS=500
AI_LITE_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.5-pro

AI_STANDARD_PROVIDER=gemini
AI_STANDARD_MODEL=gemini-2.5-flash
AI_STANDARD_CREDITS=12
AI_STANDARD_MAX_OUTPUT_TOKENS=350
AI_STANDARD_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.5-pro

AI_REASONING_PROVIDER=gemini
AI_REASONING_MODEL=gemini-2.5-pro
AI_REASONING_CREDITS=12
AI_REASONING_MAX_OUTPUT_TOKENS=1200
AI_REASONING_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite

# Gemini OpenAI-compatible API.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_REASONING_EFFORT=none
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.5-pro

# Optional OpenRouter-compatible override.
# If LLM_PROVIDER is set, it has priority over AI_PROVIDER.
LLM_PROVIDER=
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_FALLBACK_MODELS=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_FALLBACK_MODELS=
OPENROUTER_TITLE=DarkGPT Web
OPENROUTER_HTTP_REFERER=

# Optional RunPod OpenAI-compatible inference.
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
RUNPOD_OPENAI_BASE_URL=
AI_LITE_RUNPOD_ENDPOINT_ID=
AI_STANDARD_RUNPOD_ENDPOINT_ID=
AI_REASONING_RUNPOD_ENDPOINT_ID=

# Optional Replicate inference.
REPLICATE_API_TOKEN=
REPLICATE_VERSION=
AI_LITE_REPLICATE_VERSION=
AI_STANDARD_REPLICATE_VERSION=
AI_REASONING_REPLICATE_VERSION=
