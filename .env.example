# Gemini by default
APP_ENV=development
DEFAULT_LANGUAGE=ru
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
SUPPORT_USERNAME=@darkgpt_support

AI_PROVIDER=gemini
AI_TIMEOUT_SECONDS=45
AI_MAX_OUTPUT_TOKENS=700
AI_DEFAULT_TIER=standard

AI_STANDARD_PROVIDER=gemini
AI_STANDARD_MODEL=gemini-2.5-flash-lite
AI_STANDARD_CREDITS=12
AI_STANDARD_MAX_OUTPUT_TOKENS=700

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_REASONING_EFFORT=none

# Optional OpenRouter-compatible override.
# If LLM_PROVIDER is set, it has priority over AI_PROVIDER.
LLM_PROVIDER=
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_FALLBACK_MODELS=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_TITLE=DarkGPT Web
OPENROUTER_HTTP_REFERER=

# Optional RunPod OpenAI-compatible inference.
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
RUNPOD_OPENAI_BASE_URL=

# Optional Replicate inference.
REPLICATE_API_TOKEN=
REPLICATE_VERSION=

# Crypto Bot Crypto Pay top-ups.
CRYPTO_PAY_API_KEY=
CRYPTO_PAY_BASE_URL=https://pay.crypt.bot/api
